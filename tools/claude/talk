#!/usr/bin/env python3
import json
import os
import sys

TOPICS_FILE = os.path.expanduser("~/.topics.json")


def load_topics():
    if not os.path.isfile(TOPICS_FILE):
        return {}
    with open(TOPICS_FILE) as f:
        return json.load(f)


os.chdir(os.path.expanduser("~/git"))

if len(sys.argv) > 1 and not sys.argv[1].startswith("-"):
    topics = load_topics()
    if sys.argv[1] not in topics:
        print(f"Error: unknown topic '{sys.argv[1]}'", file=sys.stderr)
        if topics:
            print(f"Available topics: {', '.join(sorted(topics))}", file=sys.stderr)
        else:
            print(f"No topics found. Edit {TOPICS_FILE} to add entries.", file=sys.stderr)
        sys.exit(1)
    session_id = topics[sys.argv[1]]
    os.execvp("claude", ["claude", "--dangerously-skip-permissions", "--resume", session_id] + sys.argv[2:])
else:
    os.execvp("claude", ["claude", "--dangerously-skip-permissions"] + sys.argv[1:])
